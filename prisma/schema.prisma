// Nova ERP - Prisma Schema (Prisma + SQLite)
// مُعاد بناؤه من الجلسة السابقة + v6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================
// CORE / AUTH
// ============================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  fullName      String?
  password      String
  role          String    @default("user") // admin, accountant, engineer, hr, user
  roleId        String?
  isActive      Boolean   @default(true)
  activatedAt   DateTime?
  avatarUrl     String?
  jobTitle      String?
  employeeId    String?   @unique
  companyId     String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company?  @relation(fields: [companyId], references: [id])
  employee      Employee? @relation(fields: [employeeId], references: [id])
  notifications Notification[]
}

model Company {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  nameAr           String?
  adminEmail       String
  address          String?
  phone            String?
  logoUrl          String?
  headerLogoUrl    String?
  footerLogoUrl    String?
  primaryColor     String?
  secondaryColor   String?
  documentHeader   String?
  documentFooter   String?
  activityType     String?
  crNumber         String?
  licenseExpiryDate DateTime?
  adLicenseExpiryDate DateTime?
  email            String?
  parentCompanyId  String?
  maxUsersLimit    Int      @default(10)
  status           String   @default("active")
  subscriptionType String   @default("trial")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users            User[]
  employees        Employee[]
  clients          Client[]
  vendors          Vendor[]
  items            Item[]
  warehouses       Warehouse[]
  projects         Project[]
  journalEntries   JournalEntry[]
  cashReceipts     CashReceipt[]
  paymentVouchers  PaymentVoucher[]
  salesInvoices    SalesInvoice[]
  purchaseOrders   PurchaseOrder[]
  appointments     Appointment[]
  tasks            Task[]
  notifications    Notification[]
  paymentMethods   PaymentMethod[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String?
  description String?
  permissions String   @default("[]") // JSON array
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

}

// ============================
// HR MODULE
// ============================

model Employee {
  id                String   @id @default(cuid())
  employeeNumber    String   @unique
  fullName          String
  civilId           String?
  mobile            String?
  email             String?
  department        String?
  jobTitle          String?
  basicSalary       Float    @default(0)
  housingAllowance  Float    @default(0)
  transportAllowance Float   @default(0)
  otherAllowances   Float    @default(0)
  totalSalary       Float    @default(0)
  status            String   @default("active") // active, on-leave, terminated
  hireDate          DateTime?
  terminationDate   DateTime?
  terminationReason String?   // resignation, misconduct, end_of_contract, probation_resignation
  nationality       String?
  residencyExpiry   DateTime?
  bankName          String?
  bankAccount       String?
  // حقول قانون العمل الكويتي
  annualLeaveUsed   Float    @default(0)
  carriedLeaveDays  Float    @default(0)
  contractExpiry    DateTime?
  dob               DateTime?
  nameEn            String?
  gender            String?  // male, female
  companyId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company           Company  @relation(fields: [companyId], references: [id])
  user              User?
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  payrollRecords    PayrollRecord[]
  permissionRequests PermissionRequest[]
  custodyItems      CustodyItem[]
  gratuityCalculations GratuityCalculation[]
  custodyReconciliations CustodyReconciliation[]
  auditLogs         EmployeeAuditLog[]
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      String   @default("present") // present, absent, late, holiday, leave
  notes       String?
  createdAt   DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id])
}

model LeaveRequest {
  id          String   @id @default(cuid())
  employeeId  String
  leaveType   String   // annual, sick, emergency, unpaid
  startDate   DateTime
  endDate     DateTime
  totalDays   Int
  reason      String?
  status      String   @default("pending") // pending, approved, rejected
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id])
}

model PermissionRequest {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime
  startTime   String
  endTime     String
  reason      String?
  status      String   @default("pending")
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id])
}

model PayrollRecord {
  id              String   @id @default(cuid())
  employeeId      String
  month           Int
  year            Int
  basicSalary     Float    @default(0)
  allowances      Float    @default(0)
  deductions      Float    @default(0)
  netSalary       Float    @default(0)
  status          String   @default("draft") // draft, paid
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  employee        Employee @relation(fields: [employeeId], references: [id])
}

model CustodyItem {
  id              String   @id @default(cuid())
  employeeId      String
  name            String
  description     String?
  serialNumber    String?
  value           Float    @default(0)
  issuedDate      DateTime
  returnDate      DateTime?
  status          String   @default("issued") // issued, returned, reconciled
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        Employee @relation(fields: [employeeId], references: [id])
}

model GratuityCalculation {
  id              String   @id @default(cuid())
  employeeId      String
  calculationDate DateTime
  gratuityAmount  Float
  leaveBalancePay Float
  noticeIndemnity Float
  totalAmount     Float
  terminationReason String
  noticeType      String
  yearsOfService  Float
  createdAt       DateTime @default(now())

  employee        Employee @relation(fields: [employeeId], references: [id])
}

// Custody Reconciliation (تسوية العهد)
model CustodyReconciliation {
  id              String   @id @default(cuid())
  employeeId      String
  reconciliationNumber String @unique
  date            DateTime
  status          String   @default("draft")
  totalAmount     Float    @default(0)
  notes           String?
  settledBy       String?
  settledAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        Employee @relation(fields: [employeeId], references: [id])
  items           CustodyReconciliationItem[]
}

model CustodyReconciliationItem {
  id                  String   @id @default(cuid())
  reconciliationId    String
  description         String
  itemId              String?
  amount              Float    @default(0)
  action              String   @default("deduct")
  notes               String?
  createdAt           DateTime @default(now())

  reconciliation      CustodyReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
}

// Employee Audit Log (Time-Travel)
model EmployeeAuditLog {
  id              String   @id @default(cuid())
  employeeId      String
  field           String
  oldValue        String?
  newValue        String?
  changedBy       String?
  changedById     String?
  effectiveDate   DateTime
  reason          String?
  createdAt       DateTime @default(now())

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ============================
// CLIENTS & TRANSACTIONS
// ============================

model Client {
  id              String   @id @default(cuid())
  fileId          String?
  nameAr          String?
  nameEn          String?
  mobile          String?
  phone           String?
  email           String?
  address         String?
  city            String?
  governorate     String?
  assignedEngineer String?
  status          String   @default("new") // new, contracted, prospective, cancelled
  clientType      String   @default("registered") // registered, prospective
  frozen          Boolean  @default(false)
  notes           String?
  companyId       String
  activityTypeId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id])
  transactions    ClientTransaction[]
  quotations      Quotation[]
  salesInvoices   SalesInvoice[]
  cashReceipts    CashReceipt[]
  appointments    Appointment[]
  projects        Project[]
}

model ClientTransaction {
  id              String   @id @default(cuid())
  transactionNumber String
  clientId        String
  transactionType String?
  subServiceName  String?
  status          String   @default("new") // new, in-progress, completed, submitted, on-hold, cancelled
  assignedEngineerId String?
  totalAmount     Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id])
  contract        Contract?
  stages          TransactionStage[]
  timelineEvents  TimelineEvent[]
}

model TransactionStage {
  id              String   @id @default(cuid())
  transactionId   String
  stageId         String
  name            String
  status          String   @default("pending")
  order           Int      @default(0)
  trackingType    String   @default("duration")
  expectedDurationDays Int?
  maxOccurrences  Int?
  currentCount    Int      @default(0)
  startDate       DateTime?
  endDate         DateTime?
  expectedEndDate DateTime?
  nextStageIds    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transaction     ClientTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model TimelineEvent {
  id              String   @id @default(cuid())
  transactionId   String
  type            String   @default("comment")
  content         String
  userId          String?
  userName        String?
  userAvatar      String?
  mentionedUserIds String?
  createdAt       DateTime @default(now())

  transaction     ClientTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

// ============================
// CONTRACTS & QUOTATIONS
// ============================

model Contract {
  id              String   @id @default(cuid())
  transactionId   String   @unique
  contractNumber  String?
  totalAmount     Float    @default(0)
  startDate       DateTime?
  endDate         DateTime?
  status          String   @default("draft")
  terms           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transaction     ClientTransaction @relation(fields: [transactionId], references: [id])
  milestones      ContractMilestone[]
  salesInvoices   SalesInvoice[]
}

model ContractMilestone {
  id              String   @id @default(cuid())
  contractId      String
  name            String
  amount          Float    @default(0)
  percentage      Float?
  dueDate         DateTime?
  status          String   @default("pending")
  completedAt     DateTime?
  triggerCondition String?
  clauseStatus    String   @default("غير مستحقة")
  order           Int      @default(0)
  createdAt       DateTime @default(now())

  contract        Contract @relation(fields: [contractId], references: [id])
}

model Quotation {
  id              String   @id @default(cuid())
  quotationNumber String   @unique
  clientId        String
  subject         String?
  date            DateTime
  validUntil      DateTime?
  totalAmount     Float    @default(0)
  status          String   @default("draft")
  financialsType  String   @default("fixed") // fixed, percentage
  terms           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id])
  items           QuotationItem[]
}

model QuotationItem {
  id              String   @id @default(cuid())
  quotationId     String
  description     String
  quantity        Float    @default(1)
  unitPrice       Float    @default(0)
  total           Float    @default(0)
  order           Int      @default(0)
  createdAt       DateTime @default(now())

  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

// ============================
// ACCOUNTING
// ============================

model Account {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  nameAr          String?
  type            String   // asset, liability, equity, income, expense
  parentCode      String?
  level           Int      @default(1)
  isPayable       Boolean  @default(false)
  balanceType     String?  // Debit, Credit
  statement       String?  // Balance Sheet, Income Statement
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  journalLines    JournalLine[]
}

model JournalEntry {
  id              String   @id @default(cuid())
  entryNumber     String   @unique
  date            DateTime
  description     String?
  reference       String?
  totalDebit      Float    @default(0)
  totalCredit     Float    @default(0)
  status          String   @default("draft") // draft, posted, cancelled
  sourceType      String?
  sourceId        String?
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id])
  lines           JournalLine[]
}

model JournalLine {
  id              String   @id @default(cuid())
  journalEntryId  String
  accountId       String
  debit           Float    @default(0)
  credit          Float    @default(0)
  description     String?
  costCenterId    String?
  createdAt       DateTime @default(now())

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id])
  account         Account  @relation(fields: [accountId], references: [id])
}

model CashReceipt {
  id              String   @id @default(cuid())
  receiptNumber   String   @unique
  clientId        String
  amount          Float    @default(0)
  paymentMethod   String?
  date            DateTime
  reference       String?
  notes           String?
  status          String   @default("draft")
  journalEntryId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id])
  company         Company  @relation(fields: [companyId], references: [id])
  companyId       String
}

model PaymentVoucher {
  id              String   @id @default(cuid())
  voucherNumber   String   @unique
  payeeName       String?
  vendorId        String?
  amount          Float    @default(0)
  paymentMethod   String?
  date            DateTime
  reference       String?
  notes           String?
  status          String   @default("draft")
  journalEntryId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id])
  companyId       String
}

// ============================
// SALES & INVOICES
// ============================

model SalesInvoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  clientId        String
  contractId      String?
  date            DateTime
  totalAmount     Float    @default(0)
  status          String   @default("draft")
  description     String?
  journalEntryId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id])
  contract        Contract? @relation(fields: [contractId], references: [id])
  company         Company  @relation(fields: [companyId], references: [id])
  companyId       String
}

// ============================
// PROJECTS & CONSTRUCTION
// ============================

model Project {
  id              String   @id @default(cuid())
  projectNumber   String?
  name            String
  nameAr          String?
  clientId        String
  location        String?
  startDate       DateTime?
  endDate         DateTime?
  status          String   @default("planning") // planning, in-progress, completed, on-hold
  totalBudget     Float    @default(0)
  progressPercent Int      @default(0)
  description     String?
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id])
  company         Company  @relation(fields: [companyId], references: [id])
}

// ============================
// PURCHASING & WAREHOUSE
// ============================

model Vendor {
  id              String   @id @default(cuid())
  name            String
  nameAr          String?
  contactPerson   String?
  phone           String?
  email           String?
  address         String?
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id])
  purchaseOrders  PurchaseOrder[]
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  poNumber        String   @unique
  vendorId        String?
  vendorName      String?
  date            DateTime
  status          String   @default("draft")
  totalAmount     Float    @default(0)
  notes           String?
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor          Vendor?  @relation(fields: [vendorId], references: [id])
  company         Company  @relation(fields: [companyId], references: [id])
  items           PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  itemId          String?
  itemName        String?
  quantity        Float    @default(0)
  unitPrice       Float    @default(0)
  total           Float    @default(0)
  createdAt       DateTime @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model Item {
  id              String   @id @default(cuid())
  name            String
  nameAr          String?
  sku             String?
  description     String?
  categoryId      String?
  unit            String?
  unitPrice       Float    @default(0)
  costPrice       Float    @default(0)
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id])
}

model ItemCategory {
  id              String   @id @default(cuid())
  name            String
  parentId        String?
  order           Int      @default(0)
  createdAt       DateTime @default(now())
}

model Warehouse {
  id              String   @id @default(cuid())
  name            String
  location        String?
  companyId       String
  createdAt       DateTime @default(now())

  company         Company  @relation(fields: [companyId], references: [id])
}

// ============================
// APPOINTMENTS
// ============================

model Appointment {
  id              String   @id @default(cuid())
  clientId        String?
  clientName      String
  clientMobile    String?
  engineerId      String?
  engineerName    String?
  appointmentDate DateTime
  type            String   @default("meeting") // meeting, site-visit, first
  status          String   @default("scheduled") // scheduled, confirmed, cancelled, completed
  title           String
  notes           String?
  meetingRoom     String?
  color           String?
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client?  @relation(fields: [clientId], references: [id])
  company         Company  @relation(fields: [companyId], references: [id])
}

// ============================
// TASKS & PRODUCTIVITY
// ============================

model Task {
  id              String   @id @default(cuid())
  title           String
  description     String?
  assignedToId    String?
  assignedToName  String?
  clientId        String?
  projectId       String?
  priority        String   @default("medium") // low, medium, high, urgent
  status          String   @default("pending") // pending, in-progress, completed, cancelled
  dueDate         DateTime?
  completedAt     DateTime?
  points          Int      @default(0)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id])
  companyId       String
}

// ============================
// NOTIFICATIONS
// ============================

model Notification {
  id              String   @id @default(cuid())
  userId          String
  title           String
  body            String
  isRead          Boolean  @default(false)
  link            String?
  type            String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  company         Company  @relation(fields: [companyId], references: [id])
  companyId       String
}

// ============================
// PAYMENT METHODS
// ============================

model PaymentMethod {
  id              String   @id @default(cuid())
  name            String
  nameAr          String?
  type            String   @default("cash") // cash, bank, card, transfer
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  company         Company  @relation(fields: [companyId], references: [id])
  companyId       String
}

// ============================
// REFERENCE DATA — القوائم المرجعية الكويتية
// ============================

model Governorate {
  id          String   @id @default(cuid())
  name        String   @unique
  nameEn      String?
  code        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  areas       Area[]
}

model Area {
  id            String   @id @default(cuid())
  name          String
  nameEn        String?
  governorateId String
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  governorate   Governorate @relation(fields: [governorateId], references: [id], onDelete: Cascade)
  @@index([governorateId])
}

model Department {
  id            String   @id @default(cuid())
  name          String   @unique
  nameEn        String?
  code          String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  jobTitles     JobTitle[]
}

model JobTitle {
  id            String   @id @default(cuid())
  name          String   @unique
  nameEn        String?
  departmentId  String?
  systemRole    String   @default("engineer") // owner_executive, financial_manager, engineer
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  department    Department? @relation(fields: [departmentId], references: [id])
  @@index([departmentId])
}

model TransactionType {
  id              String   @id @default(cuid())
  name            String   @unique
  contractPath    String   @default("HYBRID_PATH")
  targetDepartment String?
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  subServices     SubService[]
}

model SubService {
  id                String   @id @default(cuid())
  name              String   @unique
  nameEn            String?
  transactionTypeId String
  domain            String   @default("INTELLECTUAL")
  defaultDeptId     String?
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  transactionType   TransactionType @relation(fields: [transactionTypeId], references: [id], onDelete: Cascade)
  @@index([transactionTypeId])
}

model WorkStage {
  id              String   @id @default(cuid())
  name            String   @unique
  nameEn          String?
  description     String?
  trackingType    String   @default("occurrence")
  expectedDurationDays Int?
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model Holiday {
  id              String   @id @default(cuid())
  name            String
  date            DateTime
  type            String   @default("national")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([date])
}

// ============================
// ROOMS & BOOKINGS
// ============================

model Room {
  id              String   @id @default(cuid())
  name            String
  capacity        Int      @default(10)
  location        String?
  facilities      String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  bookings        RoomBooking[]
}

model RoomBooking {
  id              String   @id @default(cuid())
  roomId          String
  bookedBy        String?
  title           String
  date            DateTime
  startTime       String
  endTime         String
  status          String   @default("confirmed")
  notes           String?
  createdAt       DateTime @default(now())

  room            Room     @relation(fields: [roomId], references: [id])
}
